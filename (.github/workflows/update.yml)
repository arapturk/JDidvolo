    - name: Güncellenen Dosyaları GitHub'a Commit Et ve Pushla
      run: |
        git config --local user.email "github-actions[bot]@://github.com"
        git config --local user.name "github-actions[bot]"
        git add vavoo_all_channels.m3u countries/*.m3u
        git diff --quiet && git diff --staged --quiet || (git commit -m "🔄 Güncelleme: Global ve Ülke Bazlı Vavoo Listeleri Yenilendi" && git push)
