name: Vavoo IPTV Auto Updater

on:
  schedule:
    # Her gün Türkiye saatiyle gece 03:00'te otomatik çalışır (UTC 00:00)
    - cron: '0 0 * * *'
  workflow_dispatch: # İsterseniz GitHub panelinden tek tıkla manuel çalıştırma butonu açar

jobs:
  update-list:
    runs-on: ubuntu-latest

    steps:
    - name: Depoyu Klonla
      uses: actions/checkout@v4

    - name: Python Kurulumu
      uses: actions/actions-setup-python@v5
      with:
        python-version: '3.10'

    - name: Bağımlılıkları Yükle
      run: |
        python -m pip install --upgrade pip
        pip install requests

    - name: Vavoo Scriptini Çalıştır
      run: python vavoo_fetcher.py

    - name: Güncellenen Dosyayı GitHub'a Commit Et ve Pushla
      run: |
        git config --local user.email "github-actions[bot]@users.noreply.github.com"
        git config --local user.name "github-actions[bot]"
        git add vavoo_channels.m3u
        git diff --quiet && git diff --staged --quiet || (git commit -m "🔄 Güncelleme: Vavoo Tüm Ülkeler Listesi Yenilendi" && git push)
